{
  "name": "petille",
  "version": "0.1.0",
  "private": true,
  "description": "Carnet d'appétences pour enfants 6-11 ans — PWA FOSS, zéro backend, zéro tracking.",
  "license": "AGPL-3.0-or-later",
  "author": "Benjamin <contact@kolapsis.com>",
  "homepage": "https://github.com/kolapsis/petille",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite-ssg build && node scripts/generate-sitemap.mjs",
    "build:spa": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@vueuse/core": "^12.0.0",
    "@vueuse/head": "^2.0.0",
    "dompurify": "^3.1.7",
    "ics": "^3.8.1",
    "idb-keyval": "^6.2.1",
    "jspdf": "^2.5.2",
    "marked": "^15.0.0",
    "pinia": "^2.3.0",
    "uuid": "^11.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@rushstack/eslint-patch": "^1.10.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.10.2",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1",
    "vite-ssg": "^0.24.2",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10",
    "workbox-window": "^7.3.0"
  }
}
