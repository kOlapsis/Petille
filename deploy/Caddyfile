{
	admin off
	auto_https off
	persist_config off
	log {
		output stdout
		format console
		level ERROR
	}
	servers {
		metrics
	}
}

:80 {
	root * /srv
	encode zstd gzip

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(self), microphone=(), geolocation=()"
		-Server
	}

	# Long cache for build-hashed assets.
	@hashed path_regexp ^/assets/.*-[A-Za-z0-9_-]{6,}\.(js|css|woff2?|png|jpg|jpeg|webp|avif|svg)$
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# Service worker + register script: no cache.
	@sw path /sw.js /registerSW.js
	header @sw Cache-Control "no-cache, no-store, must-revalidate"

	# Web manifest: short cache + correct MIME.
	@manifest path /manifest.webmanifest
	header @manifest Content-Type "application/manifest+json"
	header @manifest Cache-Control "public, max-age=3600"

	# SPA fallback — sert le HTML prérendu si dispo, sinon /index.html.
	try_files {path} {path}.html {path}/index.html /index.html
	file_server
}
